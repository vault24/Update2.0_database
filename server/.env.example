# ============================================================
# Backend environment template. Copy to `server/.env` and fill in.
# (deploy-scripts/deploy.sh generates this automatically from config.env.)
# Never commit the real .env — keep secrets out of git.
# ============================================================

# --- Database ---
DB_NAME=sipi_db
DB_USER=sipi_web
DB_PASSWORD=sipiadmin
DB_HOST=localhost
DB_PORT=5432

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=192.168.0.100,localhost,127.0.0.1

# --- CORS / CSRF / portal routing (fully dynamic) ---------------------------
# All origins are read from here — no origins are hardcoded in settings.py.
# Set the two portal origin lists; CORS_ALLOWED_ORIGINS and CSRF_TRUSTED_ORIGINS
# are derived from them automatically. Keep the student/admin sets DISJOINT.
#
# Full origins only: scheme://host[:port]  (comma-separated, no trailing slash)
STUDENT_PORTAL_ORIGINS=http://192.168.0.100
ADMIN_PORTAL_ORIGINS=http://192.168.0.100:8080
#
# Optional overrides / extras (usually leave blank — they are auto-derived):
# CORS_ALLOWED_ORIGINS=
# CSRF_TRUSTED_ORIGINS=
# EXTRA_TRUSTED_ORIGINS=      # folded into all of the above at once
#
# Behind HTTPS set these to True:
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False

# --- Email (OTP / password reset) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=vault7950@gmail.com
EMAIL_HOST_PASSWORD=quna cnjs yzfd jdcr
DEFAULT_FROM_EMAIL=SIPI Management System <your-email@gmail.com>
EMAIL_TIMEOUT=30

# --- OTP ---
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
PASSWORD_RESET_RATE_LIMIT_PER_HOUR=3
