# =============================================================================
# SIPI — SECRETS TEMPLATE
# =============================================================================
# Copy this file to  deploy-scripts/secrets.env  and fill in the values, OR
# simply run `sudo ./deploy-scripts/deploy.sh` — it creates secrets.env for
# you with strong randomly-generated values for everything except the email
# credentials (email is optional; OTP/notification emails are disabled until
# you fill those in and re-run the deploy).
#
# secrets.env is listed in .gitignore and MUST NEVER be committed.
# =============================================================================

# --- PostgreSQL -------------------------------------------------------------
# Password for the application database role (DB_USER in config.env).
# Auto-generated if left empty.
DB_PASSWORD=""

# --- Django -----------------------------------------------------------------
# Cryptographic secret key. Auto-generated once and then kept stable across
# re-deploys (changing it invalidates all sessions).
DJANGO_SECRET_KEY=""

# --- Django superuser (optional, created only if all three are set and the
#     user does not exist yet) ------------------------------------------------
DJANGO_SUPERUSER_USERNAME=""
DJANGO_SUPERUSER_EMAIL=""
DJANGO_SUPERUSER_PASSWORD=""

# --- Email (Gmail SMTP app password; used for OTP / password reset /
#     notifications). Leave empty to disable outgoing email. -------------------
EMAIL_HOST_USER=""
EMAIL_HOST_PASSWORD=""
