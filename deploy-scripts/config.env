# =============================================================================
# SIPI — CENTRAL DEPLOYMENT CONFIGURATION  (single source of truth)
# =============================================================================
# This is the ONLY file you edit for infrastructure changes (IP, domains,
# ports, paths). After editing, run:
#
#     sudo ./deploy-scripts/deploy.sh
#
# and every generated artifact is rebuilt from these values:
#   server/.env, client/*/.env, Nginx site, systemd unit, gunicorn.conf.py.
#
# SECRETS DO NOT BELONG HERE. This file is committed to git. All sensitive
# values (DB password, Django secret key, email credentials, superuser
# password) live in deploy-scripts/secrets.env — which is gitignored and
# auto-generated on first deploy. See secrets.env.example.
# =============================================================================

# ---------------------------------------------------------------------------
# 1. PUBLIC IDENTITY — the values that change when the server moves
# ---------------------------------------------------------------------------
# Public IP of this server. Used for the direct-IP fallback sites, DNS
# sanity checks before SSL issuance, and Django ALLOWED_HOSTS.
PUBLIC_IP="27.147.202.237"

# Public domains. Leave BOTH empty to deploy in pure IP mode (no domains,
# no SSL — the pre-DNS behaviour). When set, Nginx serves each portal on its
# own domain and the front-ends are built against these origins.
STUDENT_DOMAIN="spisg.gov.bd"
ADMIN_DOMAIN="su.spisg.gov.bd"

# ---------------------------------------------------------------------------
# 2. SSL / HTTPS  (Let's Encrypt)
# ---------------------------------------------------------------------------
# "true"  -> deploy obtains/renews Let's Encrypt certificates for both domains
#            and serves them over HTTPS with an HTTP->HTTPS redirect + HSTS.
# "false" -> plain HTTP (use while DNS is not pointed at PUBLIC_IP yet).
#
# Safe to flip later: set to true and re-run deploy.sh. If DNS does not yet
# resolve to PUBLIC_IP the deploy warns, stays on HTTP, and you simply re-run
# once DNS has propagated. Nothing breaks.
ENABLE_SSL="true"

# Email Let's Encrypt uses for expiry warnings (required when ENABLE_SSL=true).
LETSENCRYPT_EMAIL="vault7950@gmail.com"

# ---------------------------------------------------------------------------
# 3. PORTS
# ---------------------------------------------------------------------------
# Domain traffic always uses 80/443 (name-based virtual hosts). These ports
# are for the DIRECT-IP fallback sites (useful before DNS propagates):
#   http://PUBLIC_IP          -> student portal
#   http://PUBLIC_IP:8080     -> admin portal
STUDENT_PORT="80"
ADMIN_PORT="8080"

# Internal address the Django ASGI server listens on. Never exposed publicly;
# Nginx proxies to it on localhost only.
BACKEND_BIND="127.0.0.1:8000"

# ---------------------------------------------------------------------------
# 4. SERVER PATHS & SERVICE NAMES
# ---------------------------------------------------------------------------
PROJECT_PATH="/var/www/Update2.0_database"
SERVICE_NAME="sipi"                 # systemd unit name for the backend
NGINX_SITE_NAME="sipi"              # /etc/nginx/sites-available/<name>
RUN_AS_USER="www-data"              # user the backend runs as
ACME_WEBROOT="/var/www/letsencrypt" # webroot for Let's Encrypt challenges

# NOTE: backups are a SEPARATE system with its own config. See
# deploy-scripts/backup.conf and deploy-scripts/backup.sh / restore.sh.
# Deployment never performs backups.

# ---------------------------------------------------------------------------
# 5. DATABASE (PostgreSQL) — non-secret parts
# ---------------------------------------------------------------------------
# DB_PASSWORD lives in secrets.env (auto-generated on first deploy).
DB_NAME="sipi_db"
DB_USER="sipi_web"
DB_HOST="localhost"
DB_PORT="5432"

# ---------------------------------------------------------------------------
# 6. REDIS (Channels / WebSockets)
# ---------------------------------------------------------------------------
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

# ---------------------------------------------------------------------------
# 7. EMAIL (SMTP server) — non-secret parts
# ---------------------------------------------------------------------------
# The SMTP *server* the app sends through. The login credentials
# (EMAIL_HOST_USER / EMAIL_HOST_PASSWORD) live in secrets.env.
#
# Currently Gmail; when the institute mail server (noreply@spisg.gov.bd) is
# ready, point these at it and update the credentials in secrets.env, then
# re-run:  sudo ./deploy-scripts/deploy.sh --backend
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USE_TLS="True"                # STARTTLS (typical for port 587)
EMAIL_USE_SSL="False"               # implicit SSL (typical for port 465) — never enable both

# The From address shown on outgoing mail. Leave empty to derive it from
# EMAIL_HOST_USER, e.g.:  SIPI Management System <user@gmail.com>
# For the institute server set e.g.:
#   DEFAULT_FROM_EMAIL="SIPI Management System <noreply@spisg.gov.bd>"
DEFAULT_FROM_EMAIL="vault7950@gmail.com"

# ---------------------------------------------------------------------------
# 7b. GOOGLE SIGN-IN (student portal "Continue with Google")
# ---------------------------------------------------------------------------
# OAuth 2.0 *Web application* Client ID from the Google Cloud Console
# (APIs & Services -> Credentials). This is a PUBLIC identifier, so it is safe
# to keep here rather than in secrets.env. The same value is used by both the
# backend (verifies the token audience) and the student SPA (requests the token).
#
# In the Google Cloud Console, add these Authorized JavaScript origins:
#   https://spisg.gov.bd        (+ http://localhost:5199 for local dev)
# Leave empty to hide/disable the "Continue with Google" button entirely.
GOOGLE_OAUTH_CLIENT_ID="168683069447-vqh0v047ue8gdvc6dko81vbn83ukrfvu.apps.googleusercontent.com"

# ---------------------------------------------------------------------------
# 8. GUNICORN TUNING
# ---------------------------------------------------------------------------
# Leave GUNICORN_WORKERS empty to auto-size from CPU count (2*cores+1, max 9).
GUNICORN_WORKERS=""
GUNICORN_TIMEOUT="120"              # seconds before a stuck worker is killed
GUNICORN_GRACEFUL_TIMEOUT="30"      # seconds workers get to finish on restart
GUNICORN_MAX_REQUESTS="1000"        # recycle workers to cap memory growth
GUNICORN_LOG_DIR="/var/log/gunicorn"

# ---------------------------------------------------------------------------
# 9. NGINX TUNING
# ---------------------------------------------------------------------------
CLIENT_MAX_BODY_SIZE="25M"          # max upload size (documents/photos)
PROXY_READ_TIMEOUT="120"            # match gunicorn timeout

# ---------------------------------------------------------------------------
# 10. RUNTIME VERSIONS
# ---------------------------------------------------------------------------
NODE_MAJOR="20"                     # Node LTS installed if missing/too old
