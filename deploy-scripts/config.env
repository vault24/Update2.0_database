# =============================================================================
# SIPI deployment configuration
# -----------------------------------------------------------------------------
# Edit these values for your server, then run:  sudo ./deploy.sh
# Every deploy script reads this file, so this is the ONLY place you configure.
# =============================================================================

# --- Server / paths -------------------------------------------------------
SERVER_IP="192.168.0.100"
PROJECT_PATH="/var/www/Update2.0_database"

# Ports the two front-ends are served on by Nginx.
# Student portal is the "main" site on port 80; Admin portal on 8080.
STUDENT_PORT="80"
ADMIN_PORT="8080"

# Internal address the Django ASGI server listens on (kept local; Nginx proxies to it).
BACKEND_BIND="127.0.0.1:8000"

# --- Database (PostgreSQL) ------------------------------------------------
DB_NAME="sipi_db"
DB_USER="sipi_web"
DB_PASSWORD="sipiadmin"          # CHANGE THIS for a real deployment
DB_HOST="localhost"
DB_PORT="5432"

# --- Django ---------------------------------------------------------------
# Leave DJANGO_SECRET_KEY empty to have the script generate a strong one once
# and persist it into server/.env (it will not be regenerated on re-runs).
DJANGO_SECRET_KEY=""
DJANGO_DEBUG="False"

# Optional Django superuser to create automatically (leave blank to skip).
DJANGO_SUPERUSER_USERNAME="admin"
DJANGO_SUPERUSER_EMAIL="mahadi379377@gmail.com"
DJANGO_SUPERUSER_PASSWORD="idahamsm@"     # leave blank to skip auto-creation

# --- Email (used for OTP / password reset). Optional. --------------------
EMAIL_HOST_USER="vault7950@gmail.com"
EMAIL_HOST_PASSWORD="quna cnjs yzfd jdcr"

# --- Runtime versions -----------------------------------------------------
NODE_MAJOR="20"                  # Node LTS to install if missing/too old
SERVICE_NAME="sipi"             # systemd service name for the backend
